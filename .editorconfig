root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd}]
end_of_line = crlf

[*.py]
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,cjs,mjs,json,css,scss,html,yml,yaml}]
indent_style = space
indent_size = 2

[*.{sh,ps1}]
indent_style = space
indent_size = 4
