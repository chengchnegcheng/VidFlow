{
    "name": "vidflow-desktop",
    "version": "1.0.2",
    "description": "VidFlow",
    "main": "electron/main.js",
    "scripts": {
        "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\" \"wait-on file:frontend_port.json && npm run electron:dev\"",
        "frontend:dev": "cd frontend && npm run dev",
        "backend:dev": "cd backend && python src/main.py",
        "electron:dev": "electron .",
        "build": "npm run build:all && npm run build:electron",
        "build:all": "npm run build:frontend && npm run build:backend",
        "build:backend": "node scripts/build-backend.js",
        "build:frontend": "cd frontend && npm run build",
        "build:electron": "electron-builder --config electron-builder.json",
        "build:win": "npm run build:all && electron-builder --win --config electron-builder.json",
        "build:mac": "npm run build:all && electron-builder --mac --config electron-builder.json",
        "build:linux": "npm run build:all && electron-builder --linux --config electron-builder.json",
        "package": "electron-builder --config electron-builder.json",
        "package:win": "electron-builder --win --config electron-builder.json",
        "package:mac": "electron-builder --mac --config electron-builder.json",
        "package:linux": "electron-builder --linux --config electron-builder.json"
    },
    "keywords": [
        "video",
        "downloader",
        "electron",
        "python",
        "fastapi"
    ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "concurrently": "^8.2.2",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "png2icons": "^2.0.1",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "axios": "^1.6.2",
        "sharp": "^0.34.5"
    }
}
