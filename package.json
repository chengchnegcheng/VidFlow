{
    "name": "vidflow-desktop",
    "version": "1.0.0",
    "description": "VidFlow",
    "main": "electron/main.js",
    "scripts": {
                    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\" \"wait-on file:frontend_port.json \u0026\u0026 npm run electron:dev\"",
                    "frontend:dev": "cd frontend \u0026\u0026 npm run dev",
                    "backend:dev": "cd backend \u0026\u0026 python src/main.py",
                    "electron:dev": "electron .",
                    "build": "npm run build:all \u0026\u0026 npm run build:electron",
                    "build:all": "npm run build:frontend \u0026\u0026 npm run build:backend",
                    "build:backend": "node scripts/build/build-backend.js",
                    "build:frontend": "cd frontend \u0026\u0026 npm run build",
                    "build:electron": "electron-builder --config electron-builder.json",
                    "build:win": "npm run build:all \u0026\u0026 electron-builder --win --config electron-builder.json",
                    "build:mac": "npm run build:all \u0026\u0026 electron-builder --mac --config electron-builder.json",
                    "build:linux": "npm run build:all \u0026\u0026 electron-builder --linux --config electron-builder.json",
                    "package": "electron-builder --config electron-builder.json",
                    "package:win": "electron-builder --win --config electron-builder.json",
                    "package:mac": "electron-builder --mac --config electron-builder.json",
                    "package:linux": "electron-builder --linux --config electron-builder.json",
                    "release:archive": "node scripts/release/archive-release.js",
                    "delta": "node scripts/release/generate-delta.js",
                    "delta:list": "node scripts/release/generate-delta.js --list",
                    "delta:build": "node scripts/release/build-and-generate-delta.js",
                    "setup:mac": "bash scripts/dev/setup-mac.sh",
                    "dev:mac": "bash scripts/dev/dev-mac.sh",
                    "build-script:mac": "bash scripts/build/build-mac.sh",
                    "icons:tray": "node scripts/icons/generate-tray-icons.js"
                },
    "keywords": [
                     "video",
                     "downloader",
                     "electron",
                     "python",
                     "fastapi"
                 ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
                            "baseline-browser-mapping": "^2.9.11",
                            "concurrently": "^8.2.2",
                            "electron": "^28.0.0",
                            "electron-builder": "^24.9.1",
                            "png2icons": "^2.0.1",
                            "wait-on": "^7.2.0"
                        },
    "dependencies": {
                         "adm-zip": "^0.5.16",
                         "axios": "^1.6.2",
                         "sharp": "^0.34.5"
                     }
}
