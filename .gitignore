!backend/tools/bin/.ffmpeg_version
!backend/tools/bin/.ytdlp_version
# 注意: 这些工具应在运行时下载或包含在发布包中

backend/tools/models/         # AI 模型(运行时下载)
backend/subtitles/            # 生成的字幕文件
**/nul                        # 系统临时文件
nul

# Python embedded
backend/python_embedded/

# Frontend port config (运行时)
frontend_port.json

# 测试和覆盖率
.pytest_cache/
.coverage
htmlcov/

