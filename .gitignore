# Tools - 大文件(GitHub 100MB 限制)
# Windows 工具
backend/tools/bin/ffmpeg.exe
backend/tools/bin/ffprobe.exe
backend/tools/bin/yt-dlp.exe
resources/tools/bin/ffmpeg.exe
resources/tools/bin/ffprobe.exe
resources/tools/bin/yt-dlp.exe
# macOS 工具
resources/tools/bin/ffmpeg
resources/tools/bin/ffprobe
resources/tools/bin/yt-dlp
backend/tools/bin/ffmpeg
backend/tools/bin/ffprobe
backend/tools/bin/yt-dlp
